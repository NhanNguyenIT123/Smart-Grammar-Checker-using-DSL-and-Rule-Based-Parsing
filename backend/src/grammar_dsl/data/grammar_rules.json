  "semantic_patterns": {
    "unlikely_phrases": [
      {
        "phrase": "character school",
        "message": "The phrase \"character school\" is grammatically possible, but it sounds semantically unclear in everyday English.",
        "suggestion": "Use a clearer noun phrase or remove the unusual modifier."
      },
      {
        "phrase": "make homework",
        "message": "The common collocation is \"do homework\", not \"make homework\".",
        "suggestion": "Use \"do homework\" instead.",
        "replacement": "do homework"
      },
      {
        "phrase": "do a mistake",
        "message": "The common collocation is \"make a mistake\", not \"do a mistake\".",
        "suggestion": "Use \"make a mistake\" instead.",
        "replacement": "make a mistake"
      },
      {
        "phrase": "strong rain",
        "message": "English usually says \"heavy rain\", not \"strong rain\".",
        "suggestion": "Use \"heavy rain\" instead.",
        "replacement": "heavy rain"
      },
      {
        "phrase": "big rain",
        "message": "English usually says \"heavy rain\", not \"big rain\".",
        "suggestion": "Use \"heavy rain\" instead.",
        "replacement": "heavy rain"
      },
      {
        "phrase": "eat water",
        "message": "\"eat water\" sounds semantically odd. English usually uses \"drink water\".",
        "suggestion": "Use \"drink water\" instead.",
        "replacement": "drink water"
      },
      {
        "phrase": "drink bread",
        "message": "\"drink bread\" sounds semantically odd. English usually uses \"eat bread\".",
        "suggestion": "Use \"eat bread\" instead.",
        "replacement": "eat bread"
      },
      {
        "phrase": "hidden encourage",
        "message": "After \"by\", this phrase needs a more natural adverb/verb form. English would more naturally say \"covertly encouraging\".",
        "suggestion": "Use \"covertly encouraging\" instead.",
        "replacement": "covertly encouraging"
      },
      {
        "phrase": "children's bully",
        "message": "\"bully\" names a person, but this context needs the action noun \"bullying\".",
        "suggestion": "Use \"children’s bullying\" instead.",
        "replacement": "children’s bullying"
      },
      {
        "phrase": "unquestionable content",
        "message": "\"unquestionable\" sounds positive here. A more natural critical adjective is \"objectionable\" or \"inappropriate\".",
        "suggestion": "Use \"objectionable content\" instead.",
        "replacement": "objectionable content"
      },
      {
        "phrase": "effect on",
        "message": "\"effect\" is usually a noun here. The sentence needs the verb \"affect\".",
        "suggestion": "Use \"affect\" instead.",
        "replacement": "affect"
      },
      {
        "phrase": "designed on the wall",
        "message": "\"designed on the wall\" sounds unnatural for posters. English more naturally says \"put up on the wall\".",
        "suggestion": "Use \"put up on the wall\" instead.",
        "replacement": "put up on the wall"
      },
      {
        "phrase": "less appeal",
        "message": "After \"make\", English more naturally uses the adjective form \"less appealing\".",
        "suggestion": "Use \"less appealing\" instead.",
        "replacement": "less appealing"
      },
      {
        "phrase": "lose the traditional appeal",
        "message": "\"lose the traditional appeal\" sounds awkward here. A more natural verb is \"reduce\".",
        "suggestion": "Use \"reduce the traditional appeal\" instead.",
        "replacement": "reduce the traditional appeal"
      },
      {
        "phrase": "visiting their country",
        "message": "\"their country\" is unclear because the paragraph is talking about the city. The destination should stay consistent.",
        "suggestion": "Use \"visiting the city\" instead.",
        "replacement": "visiting the city"
      },
      {
        "phrase": "these objectionable content",
        "message": "\"content\" is usually uncountable in this context, so it should pair with a singular determiner.",
        "suggestion": "Use \"this objectionable content\" instead.",
        "replacement": "this objectionable content"
      }
    ],
